# Hefesto — local development environment.
# Copy to .env and adjust. Infra: docker compose -f docker/docker-compose.dev.yml up -d

# PostgreSQL (matches docker/docker-compose.dev.yml). Leave unset to use mock data.
# Run `pnpm db:migrate && pnpm db:seed` after configuring it.
DATABASE_URL=postgres://hefesto:hefesto@localhost:5432/hefesto

# Redis (BullMQ queue for the deploy worker)
REDIS_URL=redis://localhost:6379

# Docker Engine endpoint. Production Compose routes this through socket-proxy.
DOCKER_HOST=unix:///var/run/docker.sock

# Public hostname of this Hefesto instance (prod: your dashboard domain)
HEFESTO_HOST=localhost

# Secret for sessions/tokens — generate with: openssl rand -hex 32
HEFESTO_SECRET=change-me

# Let's Encrypt registration email (prod only, used by Traefik)
ACME_EMAIL=admin@example.com
