# Olym — local development environment.
# Copy to .env and adjust. Infra: docker compose -f docker/docker-compose.dev.yml up -d

# PostgreSQL (matches docker/docker-compose.dev.yml). Leave unset to use mock data.
# Run `pnpm db:migrate && pnpm db:seed` after configuring it.
DATABASE_URL=postgres://olym:olym@localhost:5432/olym

# Redis (BullMQ queue for the deploy worker)
REDIS_URL=redis://localhost:6379

# Optional GitHub PAT for validating and cloning private repositories.
# Prefer a fine-grained token scoped only to the required repositories.
GITHUB_TOKEN=

# Docker Engine endpoint. Production Compose routes this through socket-proxy.
DOCKER_HOST=unix:///var/run/docker.sock
OLYM_DOCKER_NETWORK=olym
TRAEFIK_CERTRESOLVER=letsencrypt

# Candidate container readiness gate before replacing the previous deployment.
DEPLOY_READINESS_PATH=/
DEPLOY_READINESS_TIMEOUT_MS=60000
DEPLOY_READINESS_INTERVAL_MS=1000

# Secret for sessions/tokens — generate with: openssl rand -hex 32
OLYM_SECRET=change-me

# This server's public IP (prod only, set by install.sh). Used to verify DNS
# when a domain is configured later from Settings — no domain is required
# to install; the dashboard is reachable over plain HTTP on this IP first.
OLYM_PUBLIC_IP=
